'>

<!ENTITY % engine_param_id '
  tts.engine.dictionaries                  |
  tts.engine.dictionaryDefaultPriorityBase |
  tts.engine.speechDBSegmentSizeMB         
'>

<!ENTITY % protected_param_id '
  tts.engine.maxAudioRate                  |
  tts.engine.disableAudio                  |
  tts.engine.allowLoggingDetails
'>


<!ENTITY % param_id '(%env_var_id; | %server_param_id; | %voice_param_id; | %api_param_id; | %preprocessor_param_id; | %ssml_param_id; | %cache_param_id; | %inet_param_id; | %log_param_id; | %misc_param_id; | %engine_param_id; )'>

<!ELEMENT SWIttsConfig (lang)+ >
<!ATTLIST SWIttsConfig version NMTOKEN #REQUIRED >
<!ELEMENT lang (param|protectedParam)* >
<!ATTLIST lang name (%lang_id;) #REQUIRED >
<!ELEMENT param (value|namedValue)+ >
<!ATTLIST param name %param_id; #REQUIRED >
<!ELEMENT protectedParam (value|namedValue)+ >
<!ATTLIST protectedParam name (%protected_param_id;) #REQUIRED >
<!ATTLIST protectedParam password NMTOKEN #REQUIRED >
<!ELEMENT value (#PCDATA) >
<!ELEMENT namedValue (#PCDATA) >
<!ATTLIST namedValue name CDATA #REQUIRED >
