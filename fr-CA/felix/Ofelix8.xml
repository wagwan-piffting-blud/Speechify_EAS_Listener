<!-- Define the structure for the XML -->

<!DOCTYPE SWIttsConfig PUBLIC "-//SpeechWorks//DTD SPEECHIFY CONFIG 1.0//EN"
                       "SWIttsConfig.dtd">

<!-- *************** CONFIG PARAMETERS ************* -->

<SWIttsConfig version="1.0.0">
<lang name="Default">

  <!-- default volume reduced for better performance on analog cards.
       You may need to modify this depending on your telephony environment -->
  <param name="tts.audio.volume">
     <value> 30 </value>
  </param>


  <param name="tts.audio.rate">
     <value> 100 </value>
  </param>

  <param name="tts.cache.dir">
     <value> ${TMPDIR}/cache_${tts.voice.name}_${tts.voice.format}_${USER} </value>
  </param>

  <param name="tts.log.diagnostic.file">
     <value> ${TMPDIR}/SWIttsDiagnosticLog_${tts.voice.name}_${tts.voice.format}_${USER}.txt </value>
  </param>

  <param name="tts.log.event.file">
     <value> </value>
     <!-- <value> ${TMPDIR}/SWIttsEventLog_${tts.voice.name}_${tts.voice.format}_${USER}.txt </value> -->
  </param>

  <param name="tts.log.contentDir">
     <value> ${TMPDIR}/SWIttsContent_${tts.voice.name}_${tts.voice.format}_${USER} </value>
  </param>

  <param name="tts.server.networkInterface">
    <value> 127.0.0.1 </value>
  </param> 

  <param name="tts.server.numPorts">
     <value> 2048 </value>
  </param>

  <param name="tts.server.port">
     <value> 5579 </value>
  </param>

  <param name="tts.voice.dir">
     <value> ${xml:base}/../.. </value>
  </param>

  <param name="tts.voice.config">
    <value> ${xml:base}/${tts.voice.name}.vcf </value>
  </param>

  <param name="tts.voice.format">
     <value> 8 </value>
  </param>

  <param name="tts.voice.language">
     <value> fr-CA </value>
  </param>

  <param name="tts.voice.name">
     <value> felix </value>
  </param>

</lang>

</SWIttsConfig>
